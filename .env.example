# ==== impress3d-bot configuration ====
PORT=3000
PUBLIC_URL=https://api.impress3d.com.br

# --- WhatsApp provider: evolution | meta ---
WA_PROVIDER=evolution

# --- Evolution API (QR pairing, no Meta token needed) ---
EVOLUTION_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=impress3d

# --- Dashboard admin ---
DASHBOARD_PASSWORD=change-me
DASHBOARD_SECRET=

# --- Meta / WhatsApp Cloud API (only if WA_PROVIDER=meta) ---
VERIFY_TOKEN=
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
APP_SECRET=
GRAPH_API_VERSION=v21.0

# --- AI provider: anthropic | openai ---
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Behaviour ---
HISTORY_TURNS=12
HUMAN_HANDOFF_KEYWORD=atendente
